// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CategoryStyle {
  BRIDAL
  SEMI_BRIDAL
  GOWN
  JEWELLERY
}

enum JewelleryType {
  NECKLACE
  EARRINGS
  MAANG_TIKKA
  BANGLE
  BRACELET
  RING
  NATH
  WAIST_BELT
  ANKLET
  BROOCH
  SET
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY_FOR_PICKUP
  PICKED_UP
  RETURNED
  FULFILLED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  ONLINE
  PICKUP
}

enum DepositRefundStatus {
  NOT_APPLICABLE
  PENDING
  REFUNDED
  FAILED
}

enum RentalItemType {
  LEHENGA
  JEWELLERY
}

enum CheckoutPaymentAttemptStatus {
  INITIATED
  VERIFIED
  CANCELLED
  EXPIRED
}

model AdminUser {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  phone         String?       @unique
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdOrders RentalOrder[] @relation("OrderCreatedByAdmin")
}

model Customer {
  id        String        @id @default(cuid())
  firstName String
  lastName  String?
  email     String?       @unique
  phone     String        @unique
  passwordHash String?
  notes     String?
  orders    RentalOrder[]
  reviews   ProductReview[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  style          CategoryStyle   @unique
  description    String?
  isFeatured     Boolean         @default(false)
  lehengas       Lehenga[]
  jewelleryItems Jewellery[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Lehenga {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  sku               String            @unique
  shortDescription  String?
  description       String?
  designer          String?
  color             String?
  fabric            String?
  embroideryDetails String?
  occasion          String?
  setIncludes       String?
  careInstructions  String?
  rentalPricePerDay Decimal           @db.Decimal(10, 2)
  discountPercent   Decimal           @default(0) @db.Decimal(5, 2)
  securityDeposit   Decimal?          @db.Decimal(10, 2)
  originalPrice     Decimal?          @db.Decimal(10, 2)
  minimumRentalDays Int               @default(1)
  pickupAvailable   Boolean           @default(true)
  status            ProductStatus     @default(DRAFT)
  isFeatured        Boolean           @default(false)
  isCategoryFeatured Boolean          @default(false)
  categoryId        String?
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sizes             LehengaSize[]
  images            LehengaImage[]
  orderItems        RentalOrderItem[]
  reviews           ProductReview[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@index([isCategoryFeatured])
}

model LehengaSize {
  id               String            @id @default(cuid())
  lehengaId        String
  lehenga          Lehenga           @relation(fields: [lehengaId], references: [id], onDelete: Cascade)
  sizeLabel        String
  blouseSize       String?
  waistInInches    Decimal?          @db.Decimal(5, 2)
  bustInInches     Decimal?          @db.Decimal(5, 2)
  hipInInches      Decimal?          @db.Decimal(5, 2)
  lengthInInches   Decimal?          @db.Decimal(5, 2)
  quantityTotal    Int               @default(1)
  quantityReserved Int               @default(0)
  notes            String?
  orderItems       RentalOrderItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([lehengaId, sizeLabel])
  @@index([sizeLabel])
}

model LehengaImage {
  id        String   @id @default(cuid())
  lehengaId String
  lehenga   Lehenga  @relation(fields: [lehengaId], references: [id], onDelete: Cascade)
  imageUrl  String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([lehengaId, sortOrder])
}

model Jewellery {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  sku               String            @unique
  shortDescription  String?
  description       String?
  type              JewelleryType     @default(OTHER)
  material          String?
  color             String?
  finish            String?
  stoneDetails      String?
  occasion          String?
  rentalPricePerDay Decimal           @db.Decimal(10, 2)
  securityDeposit   Decimal?          @db.Decimal(10, 2)
  originalPrice     Decimal?          @db.Decimal(10, 2)
  minimumRentalDays Int               @default(1)
  stockQuantity     Int               @default(1)
  pickupAvailable   Boolean           @default(true)
  status            ProductStatus     @default(DRAFT)
  isFeatured        Boolean           @default(false)
  categoryId        String?
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images            JewelleryImage[]
  orderItems        RentalOrderItem[]
  reviews           ProductReview[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

model JewelleryImage {
  id          String    @id @default(cuid())
  jewelleryId String
  jewellery   Jewellery @relation(fields: [jewelleryId], references: [id], onDelete: Cascade)
  imageUrl    String
  altText     String?
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([jewelleryId, sortOrder])
}

model StoreLocation {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  phone        String?
  email        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String        @default("India")
  pickupNotes  String?
  isActive     Boolean       @default(true)
  orders       RentalOrder[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model RentalOrder {
  id                  String            @id @default(cuid())
  orderNumber         String            @unique
  customerId          String
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  pickupLocationId    String
  pickupLocation      StoreLocation     @relation(fields: [pickupLocationId], references: [id], onDelete: Restrict)
  createdByAdminId    String?
  createdByAdmin      AdminUser?        @relation("OrderCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  status              OrderStatus       @default(PENDING)
  paymentStatus       PaymentStatus     @default(PENDING)
  paymentMethod       PaymentMethod     @default(PICKUP)
  rentalStartDate     DateTime
  rentalEndDate       DateTime
  pickupDate          DateTime?
  returnDate          DateTime?
  subtotalAmount      Decimal           @db.Decimal(12, 2)
  securityDeposit     Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal           @db.Decimal(12, 2)
  amountPaid          Decimal           @default(0) @db.Decimal(12, 2)
  amountDueAtPickup   Decimal           @default(0) @db.Decimal(12, 2)
  depositRefundStatus DepositRefundStatus @default(NOT_APPLICABLE)
  depositRefundedAmount Decimal         @default(0) @db.Decimal(12, 2)
  depositRefundedAt   DateTime?
  depositRefundReference String?
  depositRefundNotes  String?
  paymentGatewayOrderId String?
  paymentGatewayPaymentId String?           @unique
  paymentGatewaySignature String?
  paymentCapturedAt   DateTime?
  specialInstructions String?
  internalNotes       String?
  items               RentalOrderItem[]
  paymentAttempt      CheckoutPaymentAttempt?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([customerId])
  @@index([pickupLocationId])
  @@index([status])
  @@index([rentalStartDate, rentalEndDate])
}

model CheckoutPaymentAttempt {
  id                    String                       @id
  paymentGatewayOrderId String                       @unique
  paymentGatewayPaymentId String?                    @unique
  paymentMethod         PaymentMethod
  paymentAmount         Decimal                      @db.Decimal(12, 2)
  checkoutPayload       Json
  customerId            String?
  status                CheckoutPaymentAttemptStatus @default(INITIATED)
  expiresAt             DateTime
  rentalOrderId         String?                      @unique
  rentalOrder           RentalOrder?                 @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@index([status, expiresAt])
  @@index([customerId])
}

model RentalOrderItem {
  id                  String         @id @default(cuid())
  orderId             String
  order               RentalOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType            RentalItemType
  lehengaId           String?
  lehenga             Lehenga?       @relation(fields: [lehengaId], references: [id], onDelete: Restrict)
  lehengaSizeId       String?
  lehengaSize         LehengaSize?   @relation(fields: [lehengaSizeId], references: [id], onDelete: Restrict)
  jewelleryId         String?
  jewellery           Jewellery?     @relation(fields: [jewelleryId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  skuSnapshot         String
  sizeLabelSnapshot   String?
  quantity            Int            @default(1)
  rentalStartDate     DateTime
  rentalEndDate       DateTime
  pricePerDay         Decimal        @db.Decimal(10, 2)
  rentalDays          Int
  lineTotal           Decimal        @db.Decimal(12, 2)
  depositAmount       Decimal        @default(0) @db.Decimal(12, 2)
  measurementUpper    String?
  measurementChest    String?
  measurementWaist    String?
  measurementArmHole  String?
  measurementMori     String?
  measurementNotes    String?
  createdAt           DateTime       @default(now())

  @@index([orderId])
  @@index([lehengaId])
  @@index([jewelleryId])
  @@index([lehengaSizeId])
}

model ProductReview {
  id          String         @id @default(cuid())
  customerId  String
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  itemType    RentalItemType
  lehengaId   String?
  lehenga     Lehenga?       @relation(fields: [lehengaId], references: [id], onDelete: SetNull)
  jewelleryId String?
  jewellery   Jewellery?     @relation(fields: [jewelleryId], references: [id], onDelete: SetNull)
  rating      Int
  comment     String
  isVisible   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([customerId])
  @@index([lehengaId])
  @@index([jewelleryId])
  @@index([itemType, createdAt])
}
