{
  "name": "lehenga-admin-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "admin:create": "npm run build && node dist/scripts/create-admin.js",
    "catalog:import": "npm run build && node dist/scripts/import-lehengas.js",
    "catalog:import:dry": "npm run build && node dist/scripts/import-lehengas.js --dry-run",
    "build": "tsc -p tsconfig.json",
    "dev": "sh -c 'npm run build && (tsc -p tsconfig.json --watch --preserveWatchOutput &) && node --watch dist/server.js'",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "redis": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
