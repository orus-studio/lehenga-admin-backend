PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/lehenga
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
CLOUDFRONT_DOMAIN=https://your-distribution.cloudfront.net
REDIS_URL=redis://localhost:6379
CATALOG_CACHE_TTL_SECONDS=300
CATALOG_CACHE_STALE_TTL_SECONDS=86400
CATALOG_CACHE_DISABLED=false
AVAILABILITY_CACHE_TTL_SECONDS=30

# Meta WhatsApp Cloud API. Create an approved Utility template named
# rental_order_confirmation with 10 body variables in the order documented in README.md.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_ORDER_TEMPLATE_NAME=rental_order_confirmation
WHATSAPP_TEMPLATE_LANGUAGE=en
STORE_CONTACT_PHONE=
STORE_CONTACT_EMAIL=
